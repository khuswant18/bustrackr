generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  DRIVER
  PARENT
}

enum RouteType {
  MORNING
  AFTERNOON
  SPECIAL
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ABORTED
}

enum BoardingMethod {
  QR_SCAN
  MANUAL_CHECK
  SELF_SCAN
}

enum NotifType {
  STUDENT_BOARDED
  STUDENT_MISSED_BUS
  BUS_APPROACHING
  TRIP_STARTED
  TRIP_COMPLETED
  TRIP_DELAYED
  CUSTOM
}

model School {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String
  state     String
  country   String   @default("IN")
  timezone  String   @default("Asia/Kolkata")
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  students Student[]
  buses    Bus[]
  routes   Route[]
}

model User {
  id        String   @id @default(cuid())
  schoolId  String
  email     String   @unique
  phone     String?
  name      String
  avatarUrl String?
  role      UserRole
  fcmToken  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  children Student[] @relation("ParentStudents")
  trips    Trip[]    @relation("DriverTrips")

  @@index([schoolId, role])
}

model Student {
  id          String   @id @default(cuid())
  schoolId    String
  parentId    String
  routeStopId String?
  name        String
  grade       String?
  qrCode      String   @unique @default(cuid())
  photoUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school         School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent         User            @relation("ParentStudents", fields: [parentId], references: [id])
  defaultStop    RouteStop?      @relation(fields: [routeStopId], references: [id])
  boardingEvents BoardingEvent[]
  notifications  Notification[]

  @@index([schoolId])
  @@index([parentId])
}

model Bus {
  id          String   @id @default(cuid())
  schoolId    String
  plateNumber String   @unique
  model       String?
  capacity    Int      @default(40)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  trips  Trip[]

  @@index([schoolId])
}

model Route {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  type      RouteType @default(MORNING)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  school School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  stops  RouteStop[]
  trips  Trip[]

  @@index([schoolId])
}

model RouteStop {
  id       String @id @default(cuid())
  routeId  String
  name     String
  lat      Float
  lng      Float
  sequence Int

  route    Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  students Student[]

  @@unique([routeId, sequence])
  @@index([routeId])
}

model Trip {
  id            String     @id @default(cuid())
  routeId       String
  busId         String
  driverId      String
  status        TripStatus @default(SCHEDULED)
  scheduledAt   DateTime
  startedAt     DateTime?
  endedAt       DateTime?
  routeSnapshot Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  route          Route           @relation(fields: [routeId], references: [id])
  bus            Bus             @relation(fields: [busId], references: [id])
  driver         User            @relation("DriverTrips", fields: [driverId], references: [id])
  locationPings  LocationPing[]
  boardingEvents BoardingEvent[]

  @@index([routeId, status])
  @@index([busId])
  @@index([driverId])
  @@index([scheduledAt])
}

model LocationPing {
  id                String   @id @default(cuid())
  tripId            String
  lat               Float
  lng               Float
  accuracy          Float?
  speed             Float?
  heading           Float?
  syncedFromOffline Boolean  @default(false)
  capturedAt        DateTime
  syncedAt          DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, capturedAt])
}

model BoardingEvent {
  id        String         @id @default(cuid())
  tripId    String
  studentId String
  method    BoardingMethod @default(QR_SCAN)
  lat       Float?
  lng       Float?
  notes     String?
  boardedAt DateTime       @default(now())

  trip    Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id])

  @@unique([tripId, studentId])
  @@index([studentId])
  @@index([tripId])
}

model Notification {
  id        String    @id @default(cuid())
  studentId String
  type      NotifType
  title     String
  body      String
  payload   Json?
  delivered Boolean   @default(false)
  sentAt    DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId, sentAt])
}
